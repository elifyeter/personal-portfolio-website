<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Bio Site</title>


    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        
    </style>
</head>
<body>

    <nav class="navbar" style="background-color: #3D4E66;">
      <div class="container-fluid px-2">

        <a class="navbar-brand w-100" href="#">
          <img src="~/images/logooo2.png"
               alt="Logo"
               class="img-fluid w-100"
               style="max-height: 150px; object-fit: contain;">
        </a>


        <div class="menu-container">
          <ul class="navbar-nav justify-content-between flex-row mt-3">

            <li class="nav-item flex-fill">
              <a class="nav-link d-flex align-items-center justify-content-center"
                 asp-controller="Home" asp-action="Index">Anasayfa</a>
            </li>

            <li class="nav-item flex-fill">
              <a class="nav-link d-flex align-items-center justify-content-center"
                 asp-controller="Home" asp-action="Cv">Özgeçmiş</a>
            </li>

            <li class="nav-item flex-fill">
              <a class="nav-link d-flex align-items-center justify-content-center" 
                 asp-controller="Home" asp-action="Projects">Projeler</a>
            </li>

            <li class="nav-item flex-fill">
              <a class="nav-link d-flex align-items-center justify-content-center" 
                 asp-controller="Home" asp-action="Contact">İletişim</a>
            </li> 
            
          </ul>
        </div>

      </div>
    </nav>


    <!-- İçerik -->
    <div class="content">
        @RenderBody() 
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>